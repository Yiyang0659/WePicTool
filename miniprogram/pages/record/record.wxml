<!--pages/record/record.wxml-->
<view class="record-page">
  <!-- 顶部统计 -->
  <view class="record-header">
    <view class="record-stat">
      <view class="stat-item">
        <text class="stat-num">{{totalRecords}}</text>
        <text class="stat-label">历史记录</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">{{totalImages}}</text>
        <text class="stat-label">处理图片</text>
      </view>
    </view>
  </view>

  <!-- 记录列表 -->
  <scroll-view class="record-scroll" scroll-y="true" enhanced="true" show-scrollbar="false" wx:if="{{!isEmpty}}">
    <view class="record-list">
      <view class="date-group" wx:for="{{groupedRecords}}" wx:for-item="group" wx:key="date">
        <view class="date-title">{{group.date}}</view>

        <view class="record-card" wx:for="{{group.records}}" wx:for-item="record" wx:key="recordId">
          <view class="record-card-content" bindtap="onViewRecord" data-recordid="{{record.recordId}}">
            <view class="record-thumbnails">
              <image
                class="record-thumb {{index > 0 ? 'record-thumb-stack' : ''}}"
                wx:for="{{record.thumbnails}}"
                wx:for-item="thumb"
                wx:key="*this"
                src="{{thumb}}"
                mode="aspectFill"
                lazy-load="true"
              />
              <view class="record-count" wx:if="{{record.totalCount > record.thumbnails.length}}">+{{record.totalCount - record.thumbnails.length}}</view>
            </view>

            <view class="record-info">
              <view class="record-time">{{record.time}}</view>
              <view class="record-summary">
                <text wx:for="{{record.groupSummaryList}}" wx:key="*this" class="summary-tag">{{item}}</text>
              </view>
            </view>
          </view>

          <view class="record-actions">
            <view class="record-action" bindtap="onViewRecord" data-recordid="{{record.recordId}}">查看</view>
            <view class="record-action record-action-primary" bindtap="onRegenerate" data-recordid="{{record.recordId}}">再次生成</view>
            <view class="record-action record-action-danger" bindtap="onDeleteRecord" data-recordid="{{record.recordId}}">删除</view>
          </view>
        </view>
      </view>
    </view>

    <view class="record-footer">━━ 已经到底了 ━━</view>
  </scroll-view>

  <!-- 空态 -->
  <view class="empty-state" wx:if="{{isEmpty}}">
    <view class="empty-icon">🖼️</view>
    <view class="empty-title">暂无抠图记录</view>
    <view class="empty-text">快去体验一键抠图功能吧</view>
    <view class="empty-btn" bindtap="onGoHome">立即抠图</view>
  </view>

  <!-- 清空确认弹窗 -->
  <view class="clear-mask {{showClearConfirm ? 'clear-mask-show' : ''}}" wx:if="{{showClearConfirm}}" bindtap="onCancelClear">
    <view class="clear-dialog" catchtap="onDialogTap">
      <view class="clear-title">确认清空？</view>
      <view class="clear-text">清空后将无法恢复，是否继续？</view>
      <view class="clear-btns">
        <view class="clear-btn clear-btn-cancel" bindtap="onCancelClear">取消</view>
        <view class="clear-btn clear-btn-confirm" bindtap="onConfirmClear">清空</view>
      </view>
    </view>
  </view>
</view>
