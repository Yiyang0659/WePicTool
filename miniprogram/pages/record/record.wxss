/* pages/record/record.wxss */

page {
  background-color: #f6f6f8;
}

.record-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f6f6f8;
}

/* ===== 顶部统计条 ===== */
.stats-card {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  margin: 24rpx 24rpx 0;
  padding: 32rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
}

.stat-item + .stat-item {
  margin-left: 0;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #111111;
  line-height: 1.2;
}

.stat-label {
  font-size: 22rpx;
  color: #999999;
  margin-top: 6rpx;
}

.stat-divider {
  width: 2rpx;
  height: 56rpx;
  background-color: #ececf0;
  margin: 0 48rpx;
}

.stat-clear {
  margin-left: auto;
  font-size: 22rpx;
  color: #999999;
  padding: 12rpx 0 12rpx 24rpx;
}

.stat-clear:active {
  opacity: 0.6;
}

/* ===== 分类 tab 条 ===== */
.type-tabs {
  flex-shrink: 0;
  white-space: nowrap;
  padding: 24rpx 24rpx 0;
  box-sizing: border-box;
}

.type-tabs-inner {
  display: inline-flex;
  align-items: center;
}

.type-tab {
  display: inline-flex;
  align-items: center;
  font-size: 24rpx;
  color: #555555;
  background-color: #f2f2f4;
  border-radius: 999rpx;
  padding: 14rpx 30rpx;
  margin-right: 16rpx;
}

.type-tab:last-child {
  margin-right: 0;
}

.type-tab-active {
  color: #ffffff;
  background: linear-gradient(135deg, #4f6bf5, #6a3df0);
  box-shadow: 0 6rpx 16rpx rgba(106, 61, 240, 0.22);
}

.type-tab:active {
  opacity: 0.85;
}

/* ===== 记录列表 ===== */
.record-scroll {
  flex: 1;
  overflow: hidden;
}

.record-list {
  padding: 8rpx 24rpx 0;
}

.date-group {
  margin-bottom: 8rpx;
}

.date-title {
  font-size: 24rpx;
  color: #999999;
  margin: 24rpx 0 16rpx;
  padding-left: 8rpx;
}

/* 记录卡 */
.record-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.type-chip {
  font-size: 22rpx;
  color: #4f6bf5;
  background-color: #eef3ff;
  border-radius: 999rpx;
  padding: 8rpx 20rpx;
}

.card-time {
  font-size: 22rpx;
  color: #999999;
}

.card-body {
  display: flex;
  align-items: center;
}

/* 堆叠缩略图（最多 4 张错位堆叠） */
.record-thumbnails {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.record-thumb {
  position: absolute;
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background-color: #f2f2f4;
  border: 2rpx solid #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.record-thumb:nth-child(1) {
  top: 0;
  left: 0;
  z-index: 4;
}

.record-thumb:nth-child(2) {
  top: 12rpx;
  left: 12rpx;
  z-index: 3;
}

.record-thumb:nth-child(3) {
  top: 24rpx;
  left: 24rpx;
  z-index: 2;
}

.record-thumb:nth-child(4) {
  top: 36rpx;
  left: 36rpx;
  z-index: 1;
}

.record-count {
  position: absolute;
  right: 0;
  bottom: 0;
  z-index: 5;
  background-color: rgba(0, 0, 0, 0.55);
  color: #ffffff;
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

/* 摘要区 */
.record-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.record-summary {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.summary-tag {
  font-size: 22rpx;
  color: #555555;
  background-color: #f2f2f4;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
}

.record-total {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

.record-snippet {
  font-size: 24rpx;
  color: #999999;
  margin-top: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 卡底操作行 */
.card-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 32rpx;
  border-top: 1rpx solid #f2f2f4;
  margin-top: 20rpx;
  padding-top: 20rpx;
}

.action {
  font-size: 26rpx;
  color: #555555;
}

.action:active {
  opacity: 0.6;
}

.action-view {
  color: #4f6bf5;
}

.action-del {
  color: #ef4444;
}

.record-footer {
  text-align: center;
  font-size: 24rpx;
  color: #aaaaaa;
  padding: 16rpx 0 calc(48rpx + env(safe-area-inset-bottom));
}

/* ===== 空态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 100rpx 60rpx;
}

.empty-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background-color: #eef3ff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.empty-emoji {
  font-size: 64rpx;
  line-height: 1;
}

.empty-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

.empty-text {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 48rpx;
}

.empty-btn {
  padding: 0 64rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #4f6bf5, #6a3df0);
  color: #ffffff;
  font-size: 28rpx;
  border-radius: 999rpx;
  box-shadow: 0 8rpx 24rpx rgba(106, 61, 240, 0.22);
}

.empty-btn:active {
  opacity: 0.9;
}

/* ===== 清空确认弹窗 ===== */
.clear-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background-color 0.3s ease;
}

.clear-mask-show {
  background-color: rgba(0, 0, 0, 0.5);
}

.clear-dialog {
  width: 540rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transform: scale(0.9);
  opacity: 0;
  transition: all 0.2s ease;
}

.clear-mask-show .clear-dialog {
  transform: scale(1);
  opacity: 1;
}

.clear-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111111;
  text-align: center;
  margin-bottom: 16rpx;
}

.clear-text {
  font-size: 26rpx;
  color: #555555;
  text-align: center;
  margin-bottom: 40rpx;
  line-height: 1.5;
}

.clear-btns {
  display: flex;
  gap: 20rpx;
}

.clear-btn {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 16rpx;
  font-size: 28rpx;
}

.clear-btn:active {
  opacity: 0.85;
}

.clear-btn-cancel {
  background-color: #f2f2f4;
  color: #555555;
}

.clear-btn-confirm {
  background-color: #f2f2f4;
  color: #ef4444;
}
