/* pages/preview/preview.wxss */

page {
  background-color: #111111;
}

.preview-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #111111;
}

/* ========== 顶部导航栏 ========== */
.custom-nav {
  background-color: #1a1a1a;
  flex-shrink: 0;
}

.nav-safe-area {
  padding-top: constant(safe-area-inset-top);
  padding-top: env(safe-area-inset-top);
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
  position: relative;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  font-size: 52rpx;
  color: #ffffff;
  line-height: 1;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 34rpx;
  font-weight: 600;
  color: #ffffff;
}

.nav-more {
  font-size: 40rpx;
  color: #ffffff;
  letter-spacing: 4rpx;
  width: 60rpx;
  text-align: right;
}

/* ========== 聊天内容区 ========== */
.chat-scroll {
  flex: 1;
  overflow: hidden;
}

.chat-container {
  padding: 20rpx 24rpx 40rpx;
}

.chat-time {
  text-align: center;
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 40rpx;
}

/* ========== 消息行（右对齐） ========== */
.chat-row {
  display: flex;
  flex-direction: row-reverse;
  align-items: flex-start;
  margin-bottom: 32rpx;
  padding-left: 100rpx;
}

/* ========== 发送者头像 ========== */
.sender-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  background-color: #2c2c2c;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* ========== 消息内容区 ========== */
.message-body {
  position: relative;
  max-width: 400rpx;
}

/* ========== 胶囊按钮（毛玻璃） ========== */
.expand-pill {
  position: absolute;
  left: -88rpx;
  top: 50%;
  transform: translateY(-50%);
  z-index: 100;
  height: 56rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 28rpx;
  background-color: rgba(60, 60, 60, 0.65);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
}

.pill-text {
  font-size: 24rpx;
  color: #ffffff;
  white-space: nowrap;
  transition: opacity 0.12s ease;
}

.pill-animating .pill-text {
  opacity: 0.6;
}

/* ========== 图片列表容器 ========== */
.card-list {
  position: relative;
  transition: height 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.card-list-collapsed {
  width: 320rpx;
  height: 420rpx;
}

.card-list-expanded {
  width: 320rpx;
}

/* ========== 单张图片卡片 ========== */
.card-item {
  border-radius: 20rpx;
  overflow: hidden;
  background-color: #ffffff;
  transition:
    transform 0.4s cubic-bezier(0.25, 0.8, 0.25, 1),
    opacity 0.4s cubic-bezier(0.25, 0.8, 0.25, 1),
    box-shadow 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.card-item-collapsed {
  position: absolute;
  top: 0;
  left: 0;
  width: 320rpx;
  height: 420rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.45);
}

.card-item-expanded {
  position: relative;
  width: 320rpx;
  height: 420rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
  transform: translateY(0) scale(1) !important;
  opacity: 1 !important;
  z-index: auto !important;
}

.card-item-expanded:last-child {
  margin-bottom: 0;
}

/* ========== 滑动层 ========== */
.swipe-layer {
  width: 100%;
  height: 100%;
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.card-img {
  width: 100%;
  height: 100%;
  display: block;
}

/* ========== 展开态操作浮层 ========== */
.card-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  justify-content: flex-end;
  padding: 12rpx 16rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.5), transparent);
}

.overlay-btn {
  font-size: 20rpx;
  color: #ffffff;
  padding: 6rpx 16rpx;
  background-color: rgba(0, 0, 0, 0.45);
  border-radius: 8rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

/* ========== 底部输入栏 ========== */
.chat-input-bar {
  background-color: #1e1e1e;
  border-top: 1rpx solid #333333;
  flex-shrink: 0;
}

.input-bar-safe {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
}

.input-bar-inner {
  display: flex;
  align-items: center;
  height: 80rpx;
}

.input-icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.input-placeholder {
  flex: 1;
  height: 72rpx;
  background-color: #2c2c2c;
  border-radius: 8rpx;
  margin: 0 16rpx;
}

/* ========== 空态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

/* ========== 底部操作栏 ========== */
.bottom-bar {
  background-color: #111111;
  border-top: 1rpx solid #2a2a2a;
  flex-shrink: 0;
}

.bottom-safe-area {
  padding: 20rpx 30rpx calc(20rpx + env(safe-area-inset-bottom));
}

.merge-send-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  background-color: #07c160;
  border-radius: 16rpx;
  border: none;
}

.merge-send-btn::after {
  border: none;
}

.merge-send-btn:active {
  background-color: #06ad56;
}

.merge-send-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}
