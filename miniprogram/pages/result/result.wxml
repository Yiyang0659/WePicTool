<!--pages/result/result.wxml-->
<view class="result-page">
  <!-- 顶部导航栏 -->
  <view class="custom-nav">
    <view class="nav-safe-area">
      <view class="nav-content">
        <view class="nav-back" bindtap="onBackHome">
          <text class="nav-back-icon">‹</text>
          <text class="nav-back-text">返回</text>
        </view>
        <view class="nav-title">滑一叠</view>
        <view class="nav-placeholder"></view>
      </view>
    </view>
  </view>

  <!-- 分组卡片内容区 -->
  <scroll-view class="result-scroll" scroll-y="true" enhanced="true" show-scrollbar="false">
    <view class="result-container">
      <!-- 顶部提示卡 -->
      <view class="tipcard" wx:if="{{!isEmpty}}">
        💡 <text class="tipcard-strong">分组整理已完成。</text>按组保存后回微信勾选「发送后合并展示」，即可形成叠图滑动对比，方便朋友挑选！
      </view>

      <!-- 「朋友视角」预览引导卡：点击走现有微信预览 -->
      <view class="friend-card" wx:if="{{!isEmpty && friendPreviewThumbs.length > 0}}" bindtap="onWechatPreview">
        <view class="friend-card-text">
          <view class="friend-card-title">朋友收到后，看到的就是这样 👀</view>
          <view class="friend-card-sub">点右边，抢先滑一滑</view>
        </view>
        <view class="friend-card-chat">
          <view class="friend-bubble">
            <image
              wx:for="{{friendPreviewThumbs}}"
              wx:key="*this"
              class="friend-thumb friend-thumb-{{index}}"
              src="{{item}}"
              mode="aspectFill"
              lazy-load="true"
            />
          </view>
        </view>
      </view>

      <!-- 跨组降级提示：所有穿搭组均不足 3 张时展示 -->
      <view wx:if="{{crossGroupHint}}" class="cross-group-hint">
        <text>{{crossGroupHint}}</text>
      </view>

      <!-- 分组卡片 -->
      <view class="card" wx:for="{{groupList}}" wx:key="key" wx:for-item="g">
        <!-- 组头：组名 + 张数 + 状态徽标 -->
        <view class="group-head">
          <text class="gname">{{g.emoji}} {{g.title}}</text>
          <text class="gcount">（{{g.count}} 张）</text>
          <text class="badge badge-{{g.badgeClass}}">{{g.badgeText}}</text>
        </view>

        <!-- 组内横向滚动缩略图 -->
        <scroll-view class="thumbs" scroll-x="true" enhanced="true" show-scrollbar="false">
          <view class="thumbs-inner">
            <view class="thumb" wx:for="{{groups[g.key]}}" wx:key="resultId" wx:for-item="it" wx:for-index="i">
              <view class="pic-wrap">
                <image
                  class="pic"
                  src="{{it.displayUrl}}"
                  mode="aspectFit"
                  bindtap="onPreviewGroupImage"
                  data-group="{{g.key}}"
                  data-index="{{i}}"
                  lazy-load="true"
                />
                <view class="num">{{it.numLabel}}</view>
                <view class="compose-mask" wx:if="{{it.composeStatus === 'composing'}}">
                  <view class="compose-spinner"></view>
                  <text class="compose-mask-text">生成中</text>
                </view>
                <view class="matting-badge" wx:if="{{it.matted === false}}">已用原图</view>
              </view>
              <view class="btn-mini" bindtap="onSaveSingleItem" data-group="{{g.key}}" data-index="{{i}}">保存单图</view>
              <view class="thumb-actions">
                <text
                  class="thumb-action"
                  wx:if="{{g.key !== 'others'}}"
                  bindtap="onToggleOriginal"
                  data-group="{{g.key}}"
                  data-index="{{i}}"
                >{{it.showMode === 'original' ? '白底' : '原图'}}</text>
                <text class="thumb-action" bindtap="onChangeCategory" data-group="{{g.key}}" data-index="{{i}}">改分类</text>
                <text
                  class="thumb-action thumb-action-retry"
                  wx:if="{{g.key !== 'others' && (it.composeStatus === 'fail' || it.matted === false)}}"
                  bindtap="onRetryItem"
                  data-group="{{g.key}}"
                  data-index="{{i}}"
                >重做</text>
              </view>
            </view>
          </view>
        </scroll-view>

        <!-- 穿搭组整组保存；其他素材组仅说明文字 -->
        <view class="group-save" wx:if="{{g.key !== 'others'}}">
          <view class="btn-grad" bindtap="onSaveGroupByKey" data-group="{{g.key}}">⬇ {{g.saveText}}</view>
        </view>
        <view class="group-note" wx:else>人像、风景等不属于穿搭类别的图片，仅支持保存单图；点图片可「改分类」捞回穿搭组。</view>
      </view>

      <!-- 兜底空白状态 -->
      <view class="empty-state" wx:if="{{isEmpty}}">
        <view class="empty-icon">📂</view>
        <view class="empty-text">未找到有效的分组结果</view>
        <button class="back-btn" bindtap="onBackHome">返回首页</button>
      </view>
    </view>
  </scroll-view>

  <!-- 底部固定操作栏 -->
  <view class="result-bar" wx:if="{{!isEmpty}}">
    <view class="ratio-chip" bindtap="onChangeRatio">{{composing && composeProgress ? '生成中 ' + composeProgress.done + '/' + composeProgress.total : (composing ? '合成中…' : ratio + ' ▸')}}</view>
    <view class="btn-preview" bindtap="onWechatPreview">💬 微信预览</view>
    <view class="btn-saveall" bindtap="onSaveAllImages">保存全部</view>
  </view>

  <!-- 比例选择弹窗 -->
  <view class="action-mask {{showRatioSheet ? 'action-mask-show' : ''}}" wx:if="{{showRatioSheet}}" bindtap="onCloseRatioSheet">
    <view class="action-panel" catchtap="onActionPanelTap">
      <view class="action-title">选择输出比例</view>
      <view class="action-list">
        <view class="action-item {{ratio === item.key ? 'action-item-active' : ''}}" wx:for="{{ratioOptions}}" wx:key="key" bindtap="onSelectRatio" data-index="{{index}}">
          <text class="action-icon">{{item.icon}}</text>
          <view class="action-content">
            <view class="action-name">{{item.label}}</view>
            <view class="action-desc">{{item.desc}}</view>
          </view>
          <text class="action-check" wx:if="{{ratio === item.key}}">✓</text>
        </view>
      </view>
      <view class="action-cancel" bindtap="onCloseRatioSheet">取消</view>
    </view>
  </view>

  <!-- 发送引导半屏浮层（保存完成后弹出，替代原文字 modal） -->
  <view class="guide-mask {{showSendGuide ? 'guide-mask-show' : ''}}" wx:if="{{showSendGuide}}" bindtap="onCloseSendGuide">
    <view class="guide-panel" catchtap="onActionPanelTap">
      <view class="guide-title">保存完成 🎉</view>
      <view class="guide-steps">
        <view class="guide-step">
          <view class="guide-num">1</view>
          <view class="guide-step-text">图片已按编号顺序保存到相册 ✓</view>
        </view>
        <view class="guide-step">
          <view class="guide-num">2</view>
          <view class="guide-step-text">打开微信，进入要发送的聊天窗口</view>
        </view>
        <view class="guide-step">
          <view class="guide-num">3</view>
          <view class="guide-step-text">多选勾选刚保存的图片（按编号顺序选）</view>
        </view>
        <view class="guide-step">
          <view class="guide-num">4</view>
          <view class="guide-step-text">发送时勾选「发送后合并展示」，朋友就能滑着看</view>
        </view>
      </view>
      <view class="guide-btn-primary" bindtap="onSendGuidePreview">去看看朋友视角</view>
      <view class="guide-btn-secondary" bindtap="onCloseSendGuide">我知道了</view>
    </view>
  </view>

  <!-- 隐藏 canvas：用于前端合成白底卡片 -->
  <canvas type="2d" id="cardComposer" class="composer-canvas"></canvas>
</view>
