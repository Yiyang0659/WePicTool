/* pages/result/result.wxss */

/* 微信聊天基础配色 */
page {
  background-color: #ededed;
}

.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #ededed;
}

/* 顶部导航栏 */
.custom-nav {
  background-color: #ffffff;
  border-bottom: 1rpx solid #d6d6d6;
  flex-shrink: 0;
}

.nav-safe-area {
  padding-top: constant(safe-area-inset-top);
  padding-top: env(safe-area-inset-top);
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 20rpx;
  position: relative;
}

.nav-back {
  display: flex;
  align-items: center;
  min-width: 120rpx;
}

.nav-back-icon {
  font-size: 48rpx;
  color: #000000;
  line-height: 1;
  margin-top: -4rpx;
}

.nav-back-text {
  font-size: 30rpx;
  color: #000000;
  margin-left: 4rpx;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 34rpx;
  font-weight: 500;
  color: #000000;
  text-align: center;
}

.nav-send {
  font-size: 30rpx;
  color: #07c160;
  min-width: 120rpx;
  text-align: right;
}

/* 聊天内容区 */
.chat-scroll {
  flex: 1;
  overflow: hidden;
}

.chat-container {
  padding: 30rpx 20rpx 40rpx;
}

.chat-time {
  text-align: center;
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 30rpx;
}

.chat-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 30rpx;
}

.chat-row-left {
  justify-content: flex-start;
}

.chat-row-right {
  justify-content: flex-end;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
  background-color: #dedede;
}

.avatar-other {
  margin-right: 16rpx;
}

.avatar-me {
  margin-left: 16rpx;
}

.avatar-placeholder {
  background-color: transparent;
}

/* 气泡基础 */
.bubble {
  max-width: 520rpx;
  position: relative;
}

.bubble-other {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.05);
}

.bubble-text {
  font-size: 30rpx;
  color: #000000;
  line-height: 1.5;
  word-break: break-all;
}

/* 我的卡片气泡 */
.bubble-card {
  background-color: #95ec69;
  border-radius: 16rpx;
  padding: 20rpx;
  overflow: hidden;
}

.bubble-card-gray {
  background-color: #f5f5f5;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #000000;
  margin-bottom: 16rpx;
  text-align: center;
  letter-spacing: 4rpx;
}

.card-preview {
  position: relative;
  width: 360rpx;
  height: 360rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-preview-img {
  width: 100%;
  height: 100%;
  opacity: 1;
  transition: opacity 0.2s ease;
}

.card-preview-img-hidden {
  opacity: 0;
}

.card-preview-stack {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.stack-layer {
  position: absolute;
  width: 100%;
  height: 100%;
  background-color: #ffffff;
  border-radius: 12rpx;
  border: 2rpx solid #e0e0e0;
}

.stack-layer-1 {
  top: 12rpx;
  left: -12rpx;
  opacity: 0.8;
}

.stack-layer-2 {
  top: 24rpx;
  left: -24rpx;
  opacity: 0.6;
}

.card-expand {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.08);
}

.card-expand-text {
  font-size: 24rpx;
  color: #666666;
}

.card-expand-arrow {
  font-size: 28rpx;
  color: #999999;
  transform: rotate(90deg);
  transition: transform 0.2s ease;
  line-height: 1;
}

.card-expand-arrow-up {
  transform: rotate(-90deg);
}

/* 展开后的横向滚动内容 */
.bubble-expanded {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  max-width: 560rpx;
}

.bubble-expanded-gray {
  background-color: #f5f5f5;
}

.expanded-scroll {
  width: 100%;
  white-space: nowrap;
}

.expanded-list {
  display: flex;
  padding: 10rpx 0;
}

.expanded-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin-right: 20rpx;
  width: 200rpx;
}

.expanded-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background-color: #f0f0f0;
}

.expanded-actions {
  display: flex;
  margin-top: 12rpx;
  gap: 12rpx;
}

.expanded-action {
  font-size: 22rpx;
  color: #666666;
  padding: 8rpx 16rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  border: 1rpx solid #e0e0e0;
}

.expanded-action-primary {
  color: #07c160;
  background-color: rgba(7, 193, 96, 0.1);
  border-color: rgba(7, 193, 96, 0.3);
}

.expanded-tip {
  text-align: center;
  font-size: 22rpx;
  color: #999999;
  margin-top: 16rpx;
}

/* 空态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 40rpx;
}

.back-btn {
  width: 240rpx;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #07c160;
  color: #ffffff;
  font-size: 28rpx;
  border-radius: 12rpx;
  text-align: center;
}

/* 底部操作栏 */
.bottom-bar {
  background-color: #ffffff;
  border-top: 1rpx solid #e5e5e5;
  flex-shrink: 0;
}

.bottom-safe-area {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  padding: 20rpx 30rpx calc(20rpx + env(safe-area-inset-bottom));
}

.secondary-actions {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.secondary-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  margin: 0 10rpx;
  background-color: #ffffff;
  border: 1rpx solid #d9d9d9;
  border-radius: 12rpx;
}

.secondary-btn:first-child {
  margin-left: 0;
}

.secondary-btn:last-child {
  margin-right: 0;
}

.secondary-icon {
  font-size: 32rpx;
  margin-bottom: 6rpx;
}

.secondary-text {
  font-size: 24rpx;
  color: #333333;
}

.primary-action {
  width: 100%;
}

/* 微信发送预览按钮 */
.preview-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 80rpx;
  background-color: #ffffff;
  border: 2rpx solid #07c160;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.preview-btn:active {
  background-color: rgba(7, 193, 96, 0.05);
}

.preview-btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #07c160;
}

.merge-send-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  background-color: #07c160;
  border-radius: 16rpx;
}

.merge-send-btn:active {
  background-color: #06ad56;
}

.merge-send-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.merge-send-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

/* 底部弹窗 */
.action-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0);
  z-index: 1000;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  transition: background-color 0.3s ease;
}

.action-mask-show {
  background-color: rgba(0, 0, 0, 0.5);
}

.action-panel {
  background-color: #f6f6f6;
  border-radius: 24rpx 24rpx 0 0;
  padding: 20rpx 20rpx calc(30rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.action-mask-show .action-panel {
  transform: translateY(0);
}

.action-title {
  text-align: center;
  font-size: 26rpx;
  color: #999999;
  padding: 20rpx 0 30rpx;
}

.action-list {
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.action-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.action-item:last-child {
  border-bottom: none;
}

.action-item:active {
  background-color: #f5f5f5;
}

.action-icon {
  font-size: 44rpx;
  margin-right: 24rpx;
}

.action-content {
  display: flex;
  flex-direction: column;
}

.action-name {
  font-size: 30rpx;
  color: #000000;
  margin-bottom: 6rpx;
}

.action-desc {
  font-size: 24rpx;
  color: #999999;
}

.action-cancel {
  text-align: center;
  padding: 30rpx 0;
  background-color: #ffffff;
  border-radius: 16rpx;
  font-size: 32rpx;
  color: #000000;
  font-weight: 500;
}

.action-cancel:active {
  background-color: #f5f5f5;
}
