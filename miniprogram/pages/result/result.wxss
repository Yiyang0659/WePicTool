/* pages/result/result.wxss */

page {
  background-color: #f6f6f8;
}

.result-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f6f6f8;
}

/* 顶部导航栏 */
.custom-nav {
  background-color: #ffffff;
  border-bottom: 1rpx solid #eeeeee;
  flex-shrink: 0;
}

.nav-safe-area {
  padding-top: constant(safe-area-inset-top);
  padding-top: env(safe-area-inset-top);
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 20rpx;
  position: relative;
}

.nav-back {
  display: flex;
  align-items: center;
  min-width: 120rpx;
}

.nav-back-icon {
  font-size: 48rpx;
  color: #333333;
  line-height: 1;
  margin-top: -4rpx;
}

.nav-back-text {
  font-size: 30rpx;
  color: #333333;
  margin-left: 4rpx;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 30rpx;
  font-weight: 600;
  color: #111111;
  text-align: center;
}

.nav-placeholder {
  min-width: 120rpx;
}

/* 分组卡片内容区 */
.result-scroll {
  flex: 1;
  overflow: hidden;
}

.result-container {
  padding: 24rpx 24rpx 40rpx;
}

/* 顶部提示卡 */
.tipcard {
  background: linear-gradient(135deg, #eef3ff, #f4efff);
  border-radius: 24rpx;
  padding: 24rpx;
  font-size: 24rpx;
  color: #4a4a68;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.tipcard-strong {
  color: #3333aa;
  font-weight: 600;
}

/* 「朋友视角」预览引导卡 */
.friend-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 24rpx;
}

.friend-card:active {
  opacity: 0.88;
}

.friend-card-text {
  flex: 1;
  margin-right: 24rpx;
}

.friend-card-title {
  font-size: 29rpx;
  font-weight: 600;
  color: #111111;
  line-height: 1.4;
}

.friend-card-sub {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

/* 右侧迷你聊天仿真块 */
.friend-card-chat {
  flex: none;
  width: 200rpx;
  height: 140rpx;
  background-color: #ededed;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.friend-bubble {
  position: relative;
  width: 150rpx;
  height: 104rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.06);
}

.friend-thumb {
  position: absolute;
  width: 56rpx;
  height: 72rpx;
  border-radius: 8rpx;
  background-color: #f0f0f0;
  border: 2rpx solid #ffffff;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.08);
}

/* 三张缩略图错位叠放；不足三张时前序位置同样成立 */
.friend-thumb-0 {
  left: 14rpx;
  top: 16rpx;
  transform: rotate(-6deg);
  z-index: 1;
}

.friend-thumb-1 {
  left: 47rpx;
  top: 16rpx;
  z-index: 2;
}

.friend-thumb-2 {
  left: 80rpx;
  top: 16rpx;
  transform: rotate(6deg);
  z-index: 3;
}

/* 发送引导半屏浮层 */
.guide-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0);
  z-index: 1100;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  transition: background-color 0.3s ease;
}

.guide-mask-show {
  background-color: rgba(0, 0, 0, 0.5);
}

.guide-panel {
  background-color: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 40rpx 32rpx calc(32rpx + constant(safe-area-inset-bottom));
  padding: 40rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.guide-mask-show .guide-panel {
  transform: translateY(0);
}

.guide-title {
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #111111;
  margin-bottom: 36rpx;
}

.guide-steps {
  margin-bottom: 40rpx;
}

.guide-step {
  display: flex;
  align-items: flex-start;
  margin-bottom: 28rpx;
}

.guide-step:last-child {
  margin-bottom: 0;
}

/* 渐变圆形编号（同首页「怎么玩」样式） */
.guide-num {
  flex: none;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4f6bf5, #6a3df0);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  margin-top: 2rpx;
}

.guide-step-text {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.5;
}

.guide-btn-primary {
  text-align: center;
  border-radius: 999rpx;
  padding: 24rpx 0;
  background: linear-gradient(135deg, #4f6bf5, #6a3df0);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.guide-btn-primary:active {
  opacity: 0.88;
}

.guide-btn-secondary {
  text-align: center;
  border-radius: 999rpx;
  padding: 24rpx 0;
  background-color: #f2f2f4;
  color: #333333;
  font-size: 30rpx;
  font-weight: 500;
}

.guide-btn-secondary:active {
  background-color: #e8e8ec;
}

/* 分组卡片 */
.card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.card + .card {
  margin-top: 24rpx;
}

/* 组头：组名 + 张数 + 状态徽标 */
.group-head {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.gname {
  font-size: 28rpx;
  font-weight: 600;
  color: #111111;
  margin-right: 12rpx;
}

.gcount {
  font-size: 24rpx;
  color: #999999;
}

.badge {
  margin-left: auto;
  font-size: 20rpx;
  font-weight: 500;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  white-space: nowrap;
}

.badge-ok {
  background-color: #e6f9ee;
  color: #07a350;
}

.badge-warn {
  background-color: #f2f2f4;
  color: #999999;
}

/* 组内横向滚动缩略图 */
.thumbs {
  width: 100%;
  white-space: nowrap;
}

.thumbs-inner {
  display: flex;
  padding-bottom: 8rpx;
}

.thumb {
  flex: none;
  width: 192rpx;
  margin-right: 16rpx;
}

.thumb:last-child {
  margin-right: 0;
}

.pic-wrap {
  position: relative;
  width: 192rpx;
  height: 240rpx;
  border-radius: 18rpx;
  background-color: #fafafa;
  border: 1rpx solid #f0f0f0;
  overflow: hidden;
}

.pic {
  width: 100%;
  height: 100%;
  display: block;
}

/* 编号角标 */
.num {
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.72);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 生成中遮罩 */
.compose-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.65);
}

.compose-mask-text {
  font-size: 22rpx;
  color: #666666;
}

/* 抠图失败兜底角标 */
.matting-badge {
  position: absolute;
  left: 8rpx;
  bottom: 8rpx;
  font-size: 20rpx;
  color: #d48806;
  background-color: rgba(255, 247, 230, 0.95);
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
}

/* 保存单图按钮 */
.btn-mini {
  margin-top: 12rpx;
  border: 1rpx solid #dddddd;
  background-color: #ffffff;
  color: #444444;
  font-size: 22rpx;
  border-radius: 14rpx;
  padding: 10rpx 0;
  text-align: center;
}

.btn-mini:active {
  background-color: #f5f5f5;
}

/* 缩略图下方小字操作：原图/改分类/重做 */
.thumb-actions {
  display: flex;
  justify-content: center;
  margin-top: 10rpx;
}

.thumb-action {
  font-size: 20rpx;
  color: #666666;
  padding: 4rpx 8rpx;
}

.thumb-action-retry {
  color: #ff3b30;
}

/* 整组保存按钮 */
.group-save {
  margin-top: 20rpx;
}

.btn-grad {
  width: 100%;
  text-align: center;
  border-radius: 20rpx;
  padding: 24rpx 0;
  background: linear-gradient(135deg, #4f6bf5, #6a3df0);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-grad:active {
  opacity: 0.88;
}

/* 其他素材组说明文字 */
.group-note {
  font-size: 22rpx;
  color: #aaaaaa;
  margin-top: 16rpx;
  line-height: 1.5;
}

/* 空态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 40rpx;
}

.back-btn {
  width: 240rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #4f6bf5, #6a3df0);
  color: #ffffff;
  font-size: 28rpx;
  border-radius: 12rpx;
  text-align: center;
}

/* 底部固定操作栏 */
.result-bar {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx calc(20rpx + constant(safe-area-inset-bottom));
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background-color: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid #eeeeee;
}

.ratio-chip {
  border: 1rpx solid #dddddd;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 18rpx 20rpx;
  font-size: 24rpx;
  color: #555555;
  white-space: nowrap;
  margin-right: 16rpx;
}

.btn-preview {
  flex: 1;
  text-align: center;
  border-radius: 20rpx;
  padding: 22rpx 8rpx;
  font-size: 26rpx;
  font-weight: 600;
  background-color: #111111;
  color: #ffffff;
  white-space: nowrap;
  margin-right: 16rpx;
}

.btn-preview:active {
  opacity: 0.85;
}

.btn-saveall {
  flex: 1;
  text-align: center;
  border-radius: 20rpx;
  padding: 22rpx 8rpx;
  font-size: 26rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #4f6bf5, #6a3df0);
  color: #ffffff;
  white-space: nowrap;
}

.btn-saveall:active {
  opacity: 0.88;
}

/* 隐藏 canvas：用于前端合成白底卡片 */
.composer-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 1px;
  height: 1px;
  opacity: 0;
  pointer-events: none;
}

/* 底部弹窗（比例选择） */
.action-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0);
  z-index: 1000;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  transition: background-color 0.3s ease;
}

.action-mask-show {
  background-color: rgba(0, 0, 0, 0.5);
}

.action-panel {
  background-color: #f6f6f6;
  border-radius: 24rpx 24rpx 0 0;
  padding: 20rpx 20rpx calc(30rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.action-mask-show .action-panel {
  transform: translateY(0);
}

.action-title {
  text-align: center;
  font-size: 26rpx;
  color: #999999;
  padding: 20rpx 0 30rpx;
}

.action-list {
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.action-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.action-item:last-child {
  border-bottom: none;
}

.action-item:active {
  background-color: #f5f5f5;
}

.action-item-active {
  background-color: rgba(79, 107, 245, 0.08);
}

.action-icon {
  font-size: 44rpx;
  margin-right: 24rpx;
}

.action-content {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.action-name {
  font-size: 30rpx;
  color: #000000;
  margin-bottom: 6rpx;
}

.action-desc {
  font-size: 24rpx;
  color: #999999;
}

.action-check {
  font-size: 32rpx;
  color: #4f6bf5;
  margin-left: 16rpx;
}

.action-cancel {
  text-align: center;
  padding: 30rpx 0;
  background-color: #ffffff;
  border-radius: 16rpx;
  font-size: 32rpx;
  color: #000000;
  font-weight: 500;
}

.action-cancel:active {
  background-color: #f5f5f5;
}
