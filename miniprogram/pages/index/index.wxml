<!--pages/index/index.wxml-->
<view class="container">
  <!-- ===== 步骤一：首页选图入口 ===== -->
  <block wx:if="{{step === 'home'}}">
    <!-- 1. 品牌区 -->
    <view class="brand-section">
      <view class="brand-logo">
        <!-- 叠图堆叠小图标：三张卡片扇形叠放，贴合“微信叠图”定位 -->
        <view class="brand-stack">
          <view class="brand-stack-card brand-stack-back"></view>
          <view class="brand-stack-card brand-stack-mid"></view>
          <view class="brand-stack-card brand-stack-top"></view>
        </view>
      </view>
      <view class="brand-info">
        <view class="brand-name">滑一叠</view>
        <view class="brand-slogan">一叠图，发得好看 · 微信叠图玩法生成器</view>
      </view>
    </view>

    <!-- 2. 朋友视角仿真演示卡：3 秒讲清产品是干嘛的 -->
    <view class="demo-card">
      <view class="demo-chat-row">
        <view class="demo-avatar"></view>
        <view class="demo-bubble">
          <swiper class="demo-swiper" autoplay interval="2000" circular indicator-dots="false">
            <swiper-item wx:for="{{demoSlides}}" wx:key="src">
              <!-- 白底编号卡样式：白底 + 左上角黑底白字序号角标 -->
              <view class="demo-slide-card">
                <view class="demo-slide-num">{{item.num}}</view>
                <image class="demo-slide-img" src="{{item.src}}" mode="aspectFit" />
              </view>
            </swiper-item>
          </swiper>
        </view>
      </view>
      <view class="demo-caption">朋友收到就能这样滑着看 👀</view>
    </view>

    <!-- 3. 旗舰主卡：穿搭叠图（双按钮：示例体验 + 选自己的图走既有 onChooseMedia） -->
    <view class="hero-card">
      <view class="hero-icon">📸</view>
      <view class="hero-title">穿搭叠图</view>
      <view class="hero-desc">AI 抠图分组 · 白底编号卡 · 回微信合并发送</view>
      <view class="hero-cta-row">
        <view class="hero-cta-ghost" catchtap="onChooseMedia">选自己的图</view>
        <view class="hero-cta" catchtap="onTrySample">用示例试一叠</view>
      </view>
    </view>

    <!-- 4. 玩法模板区 -->
    <view class="section-head">
      <view class="section-title-wrap">
        <view class="section-bar"></view>
        <view class="section-title">玩法模板</view>
      </view>
      <view class="section-side">陆续上线</view>
    </view>
    <view class="module-grid">
      <view class="module-card" wx:for="{{comingModules}}" wx:key="key" bindtap="onComingSoon">
        <view class="module-badge">即将上线</view>
        <view class="module-emoji">{{item.emoji}}</view>
        <view class="module-name">{{item.name}}</view>
        <view class="module-desc">{{item.desc}}</view>
      </view>
    </view>

    <!-- 5. 工具区 -->
    <view class="tool-card" bindtap="onComingSoon">
      <view class="tool-emoji">🗂️</view>
      <view class="tool-info">
        <view class="tool-name">资料打包</view>
        <view class="tool-desc">多图分组成叠，不再刷屏</view>
      </view>
      <view class="tool-badge">即将上线</view>
    </view>

    <!-- 6. 操作说明卡 -->
    <view class="guide-card">
      <view class="section-title-wrap guide-title-wrap">
        <view class="section-bar"></view>
        <view class="section-title">怎么玩</view>
      </view>
      <view class="guide-list">
        <view class="guide-item">
          <view class="guide-num">1</view>
          <view class="guide-text">点击「穿搭叠图」卡片的「用示例试一叠」快速体验，或点「选自己的图」选择上衣、裤子、裙子或鞋子的照片（可混选 1-9 张）。</view>
        </view>
        <view class="guide-item">
          <view class="guide-num">2</view>
          <view class="guide-text">确认图片与输出比例后，系统上传至云端进行部件智能分类与整理。</view>
        </view>
        <view class="guide-item">
          <view class="guide-num">3</view>
          <view class="guide-text">在结果页查看自动分出的【上衣组】、【下装组】和【鞋子组】，一键保存到手机相册。</view>
        </view>
        <view class="guide-item">
          <view class="guide-num">4</view>
          <view class="guide-text">发送到微信群或私聊，利用微信多图合并堆叠效果，让闺蜜/群友左右滑动帮你挑选！</view>
        </view>
      </view>
    </view>
  </block>

  <!-- ===== 步骤二：处理前确认（缩略图 + 输出比例，逻辑原样保留） ===== -->
  <view class="confirm-section" wx:if="{{step === 'confirm'}}">
    <view class="confirm-head-row">
      <view class="confirm-head">已选 {{pickedImages.length}} 张图片</view>
      <view class="confirm-repick" bindtap="onBackToHome">‹ 重新选择</view>
    </view>

    <!-- 已选图片缩略图网格（4 列，白卡容器） -->
    <view class="picked-card">
      <view class="picked-grid">
        <view class="picked-item" wx:for="{{pickedImages}}" wx:key="tempFilePath" bindtap="onPreviewConfirmImage" data-index="{{index}}">
          <image class="picked-img" src="{{item.tempFilePath}}" mode="aspectFill" lazy-load="true" />
          <!-- 单张移除：catchtap 阻止冒泡，避免同时触发预览 -->
          <view class="picked-del" catchtap="onRemoveImage" data-index="{{index}}">×</view>
        </view>
        <!-- 添加图片入口：未满 9 张时显示，点击进入本地相册继续添加 -->
        <view class="picked-add" wx:if="{{pickedImages.length < 9}}" bindtap="onAddMedia">
          <view class="picked-add-plus">＋</view>
          <view class="picked-add-text">添加</view>
        </view>
      </view>
    </view>

    <!-- 输出比例分段控件 -->
    <view class="ratio-label">输出比例（白底卡片）</view>
    <view class="ratio-seg">
      <view
        class="ratio-seg-item {{confirmRatio === item.key ? 'ratio-seg-item-on' : ''}}"
        wx:for="{{ratioOptions}}"
        wx:key="key"
        bindtap="onSelectConfirmRatio"
        data-key="{{item.key}}"
      >{{item.label}}</view>
    </view>
    <view class="ratio-note">比例只影响白底卡片合成，不重新抠图；结果页可随时修改。</view>

    <!-- 开始处理主按钮 -->
    <view class="confirm-cta {{processing ? 'confirm-cta-disabled' : ''}}" bindtap="onStartProcess">
      <view class="btn-grad">{{processing ? '处理中...' : '开始处理'}}</view>
    </view>
    <view class="confirm-hint">若包含人像、风景等非穿搭图片，将自动归入「其他素材」</view>
  </view>

  <!-- 处理中的 Loading 弹窗 -->
  <view class="loading-overlay" wx:if="{{loading}}">
    <view class="loading-box">
      <view class="spinner"></view>
      <view class="loading-text">{{loadingText}}</view>
      <view class="loading-subtext">正在处理您的穿搭素材...</view>
      <view class="loading-cancel" bindtap="onCancelProcess">取消处理</view>
    </view>
  </view>
</view>
